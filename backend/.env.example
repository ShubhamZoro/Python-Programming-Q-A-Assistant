OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
ENVIRONMENT=development
ALLOWED_ORIGIN=http://localhost:5173

# ── Pinecone (vector database for embeddings) ────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=python-qa
# Region examples: us-east-1, us-west-2, eu-west-1, gcp-starter
PINECONE_ENVIRONMENT=us-east-1

# Path to question_answer.json (for ingestion)
DATA_FILE_PATH=../question_answer.json

# How many records to ingest (set to 0 for all)
INGEST_LIMIT=50000

# Embedding model (open-source, local — no API key required)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
