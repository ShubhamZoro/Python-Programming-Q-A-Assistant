OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
ENVIRONMENT=development
ALLOWED_ORIGIN=http://localhost:5173

# Path to question_answer.json (for ingestion)
DATA_FILE_PATH=../question_answer.json

# How many records to ingest (set to 0 for all)
INGEST_LIMIT=50000

# Embedding model (open-source)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
